# Put these lines in a file named `.env` OR `.env.local` in the project root
# (same folder as package.json). Next.js loads both; `.env.local` overrides `.env`
# if the same variable appears in both. Prefer `.env.local` for secrets on a team repo.
#
# --- Option A: OpenRouter (recommended for free-tier experiments) ---
# Get a key at https://openrouter.ai/keys — many models are free or very cheap.
OPENROUTER_API_KEY=sk-or-v1-...
# Default picks OpenRouter’s free model router. Override for a specific model, e.g.:
# OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL=openrouter/free
# Optional (OpenRouter likes these for rankings; localhost is fine for dev)
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=PITCHAI
# OPENROUTER_FALLBACK_MODELS=openrouter/auto,openai/gpt-4o-mini

# --- Option B: OpenAI directly ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Natural Voice (Free, local Piper) ---
# Use the Piper HTTP root (recommended for artibex/piper-http Docker image).
# PIPER_TTS_URL=http://127.0.0.1:5002
PIPER_TTS_URL=http://127.0.0.1:5002
# Optional timeout in ms
# PIPER_TTS_TIMEOUT_MS=12000
# Optional auth token if your Piper wrapper requires it
# PIPER_TTS_API_KEY=...

# --- Server-only session dataset (for training / evals; not shown in UI) ---
# Default: JSONL under ./data/pitchai-sessions/ (see .gitignore). On read-only hosting, set=0 or a writable dir.
# PITCHAI_SESSION_DATASET=1
# PITCHAI_SESSION_DATASET=0
# PITCHAI_SESSION_DATASET_DIR=/var/pitchai/sessions

# --- Optional cloud fallback for natural voice ---
# If Piper is unavailable, /api/tts can fallback to OpenAI when this is set.
# OPENAI_API_KEY=sk-proj-...
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
